{
  "manifest_version": 3,
  "name": "SuperWeb2PDF Capture",
  "version": "1.0.0",
  "description": "Capture full-page screenshots for SuperWeb2PDF",
  "minimum_chrome_version": "109",
  "offline_enabled": true,
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
